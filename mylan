<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>خريطة تعلم الفوركس والتداول</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #ffffff;
    --surface: #f8f9fa;
    --surface2: #f0f2f5;
    --blue: #1a56db;
    --blue2: #2563eb;
    --blue-light: #eff6ff;
    --blue-border: #bfdbfe;
    --dark: #111827;
    --dark2: #1f2937;
    --gray: #6b7280;
    --gray2: #9ca3af;
    --border: #e5e7eb;
    --border2: #d1d5db;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    font-family: 'Cairo', sans-serif;
    color: var(--dark);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Subtle grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(26,86,219,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(26,86,219,0.04) 1px, transparent 1px);
    background-size: 44px 44px;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  /* Logo bar */
  .logo-bar {
    display: flex;
    justify-content: center;
    margin-bottom: 36px;
    animation: fadeDown 0.7s ease both;
  }

  .logo-img {
    width: 80px;
    height: 80px;
    object-fit: contain;
    border-radius: 16px;
    border: 2px solid var(--border);
    background: #111;
    padding: 8px;
  }

  /* Header */
  .header {
    text-align: center;
    margin-bottom: 48px;
    animation: fadeDown 0.8s 0.1s ease both;
  }

  .header-badge {
    display: inline-block;
    background: var(--blue-light);
    border: 1px solid var(--blue-border);
    color: var(--blue2);
    font-size: 12px;
    font-weight: 700;
    padding: 5px 16px;
    border-radius: 100px;
    margin-bottom: 18px;
    letter-spacing: 1px;
  }

  .header h1 {
    font-family: 'Tajawal', sans-serif;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 800;
    line-height: 1.2;
    color: var(--dark);
    margin-bottom: 10px;
  }

  .header h1 span {
    color: var(--blue2);
  }

  .header p {
    color: var(--gray);
    font-size: 15px;
    font-weight: 400;
  }

  /* Center button node */
  .center-node {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 48px;
    animation: fadeUp 0.8s 0.2s ease both;
  }

  .center-btn {
    display: inline-block;
    background: var(--dark);
    color: #fff;
    font-family: 'Tajawal', sans-serif;
    font-size: 18px;
    font-weight: 700;
    padding: 18px 44px;
    border-radius: 50px;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(17,24,39,0.18), 0 2px 6px rgba(17,24,39,0.12);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    cursor: pointer;
    border: none;
    position: relative;
    overflow: hidden;
  }

  .center-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--blue2), #1e40af);
    opacity: 0;
    transition: opacity 0.3s;
    border-radius: 50px;
  }

  .center-btn:hover::before {
    opacity: 1;
  }

  .center-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(37,99,235,0.3);
  }

  .center-btn span {
    position: relative;
    z-index: 1;
  }

  /* Arrow icon on button */
  .center-btn .arrow {
    position: relative;
    z-index: 1;
    margin-right: 10px;
    font-size: 14px;
    opacity: 0.8;
  }

  /* Path indicator */
  .path-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin: 0 0 40px;
    padding: 14px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 100px;
    animation: fadeUp 0.8s 0.3s ease both;
  }

  .path-step {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--dark2);
  }

  .path-dot {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 800;
    flex-shrink: 0;
  }

  .path-dot.d1 { background: #eff6ff; color: var(--blue2); border: 1.5px solid var(--blue-border); }
  .path-dot.d2 { background: #eff6ff; color: #2563eb; border: 1.5px solid #bfdbfe; }
  .path-dot.d3 { background: #eff6ff; color: #2563eb; border: 1.5px solid #bfdbfe; }

  .path-arrow {
    color: var(--gray2);
    font-size: 14px;
  }

  /* Section */
  .section {
    margin-bottom: 36px;
    animation: fadeUp 0.8s ease both;
  }

  .section:nth-child(1) { animation-delay: 0.35s; }
  .section:nth-child(2) { animation-delay: 0.5s; }
  .section:nth-child(3) { animation-delay: 0.65s; }

  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    padding: 16px 20px;
    border-radius: 14px;
    border: 1.5px solid;
  }

  .s1 .section-header { background: #eff6ff; border-color: var(--blue-border); }
  .s2 .section-header { background: #eff6ff; border-color: #bfdbfe; }
  .s3 .section-header { background: #eff6ff; border-color: #bfdbfe; }

  .section-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 800;
    flex-shrink: 0;
  }

  .s1 .section-num { background: var(--blue2); color: white; }
  .s2 .section-num { background: #2563eb; color: white; }
  .s3 .section-num { background: #2563eb; color: white; }

  .section-title {
    font-family: 'Tajawal', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--dark);
  }

  .section-subtitle {
    font-size: 12px;
    color: var(--gray);
    margin-top: 1px;
  }

  /* Cards grid */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
    padding-right: 16px;
  }

  .card {
    background: var(--bg);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 18px 20px;
    position: relative;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .card::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 3px;
    height: 100%;
    border-radius: 0 12px 12px 0;
    transition: width 0.2s ease;
  }

  .card:hover {
    transform: translateY(-2px);
  }

  .s1 .card::after { background: var(--blue2); }
  .s1 .card:hover { border-color: var(--blue-border); box-shadow: 0 8px 24px rgba(37,99,235,0.10); }

  .s2 .card::after { background: #2563eb; }
  .s2 .card:hover { border-color: #bfdbfe; box-shadow: 0 8px 24px rgba(22,163,74,0.10); }

  .s3 .card::after { background: #2563eb; }
  .s3 .card:hover { border-color: #bfdbfe; box-shadow: 0 8px 24px rgba(234,88,12,0.10); }

  .card-num {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 6px;
    opacity: 0.45;
    color: var(--dark);
  }

  .card-title {
    font-family: 'Tajawal', sans-serif;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 5px;
    color: var(--dark);
  }

  .card-desc {
    font-size: 12.5px;
    color: var(--gray);
    line-height: 1.6;
  }

  /* Sub-cards */
  .sub-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 12px;
    padding-right: 16px;
  }

  .sub-card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .sub-card:hover { transform: translateY(-2px); border-color: #bfdbfe; }

  .sub-card-label {
    font-size: 10px;
    font-weight: 700;
    color: #2563eb;
    letter-spacing: 1px;
    margin-bottom: 5px;
    opacity: 0.7;
  }

  .sub-card-title {
    font-family: 'Tajawal', sans-serif;
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 3px;
    color: var(--dark);
  }

  .sub-card-en {
    font-size: 11px;
    color: #2563eb;
    font-weight: 600;
    direction: ltr;
    text-align: left;
  }

  /* Footer */
  .footer {
    text-align: center;
    margin-top: 50px;
    color: var(--gray2);
    font-size: 12px;
    animation: fadeUp 0.8s 0.8s ease both;
  }

  /* Divider */
  .divider {
    border: none;
    border-top: 1.5px solid var(--border);
    margin: 28px 0 0;
  }

  /* Animations */
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 600px) {
    .cards-grid { grid-template-columns: 1fr; }
    .sub-cards { grid-template-columns: 1fr 1fr; }
    .path-bar { flex-wrap: wrap; border-radius: 16px; gap: 8px; }
    .center-btn { font-size: 15px; padding: 15px 30px; }
  }
</style>
</head>
<body>

<div class="container">

  <!-- Logo -->
  <div class="logo-bar">
    <img class="logo-img" src="data:image/jpeg;base64,
